<Window x:Class="Awareness.Progress.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:Awareness.Resources"
        Title="{x:Static res:Strings.ProgressTitle}"
        Width="360" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop x:Name="TopGradientStop" Color="#FFF9EBD7" Offset="0" />
            <GradientStop x:Name="BottomGradientStop" Color="#FFEDD9C7" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Twin Donut Charts (Today + Overall) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,4">
                <StackPanel HorizontalAlignment="Center">
                    <Canvas x:Name="TodayDonutCanvas" Width="120" Height="120" />
                    <TextBlock Text="{x:Static res:Strings.Today}" FontSize="11" Foreground="Gray"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" Margin="20,0,0,0">
                    <Canvas x:Name="LifetimeDonutCanvas" Width="120" Height="120" />
                    <TextBlock Text="{x:Static res:Strings.Lifetime}" FontSize="11" Foreground="Gray"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Stats -->
            <StackPanel Margin="0,8,0,8">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontWeight="SemiBold"
                               Text="{x:Static res:Strings.Today}" />
                    <TextBlock Grid.Column="1" x:Name="TodayText"
                               HorizontalAlignment="Right" Foreground="Gray" />
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontWeight="SemiBold"
                               Text="{x:Static res:Strings.Lifetime}" />
                    <TextBlock Grid.Column="1" x:Name="LifetimeText"
                               HorizontalAlignment="Right" Foreground="Gray" />
                </Grid>
            </StackPanel>

            <Separator Margin="0,4" />

            <!-- 14-Day Bar Chart (Triggered/Completed) -->
            <Canvas x:Name="BarChartCanvas" Height="120"
                    HorizontalAlignment="Stretch" Margin="0,12,0,4" />

            <!-- Legend -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                <Rectangle Width="8" Height="8" Fill="#66808080" RadiusX="1" RadiusY="1" />
                <TextBlock Text="{x:Static res:Strings.Triggered}" Foreground="Gray"
                           FontSize="10" Margin="4,0,12,0" VerticalAlignment="Center" />
                <Rectangle Width="8" Height="8" Fill="#B88061" RadiusX="1" RadiusY="1" />
                <TextBlock Text="{x:Static res:Strings.Completed}" Foreground="Gray"
                           FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <Separator Margin="0,4" />

            <!-- Awareness Candlestick Chart -->
            <Canvas x:Name="AwarenessChartCanvas" Height="100"
                    HorizontalAlignment="Stretch" Margin="0,12,0,4" />

            <!-- Awareness Legend -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Rectangle Width="1" Height="10" Fill="#66808080" />
                <TextBlock Text="{x:Static res:Strings.Range}" Foreground="Gray"
                           FontSize="10" Margin="4,0,12,0" VerticalAlignment="Center" />
                <Ellipse Width="5" Height="5" Fill="#B88061" />
                <TextBlock Text="{x:Static res:Strings.Median}" Foreground="Gray"
                           FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <Separator x:Name="DurationSeparator" Margin="0,4" Visibility="Collapsed" />

            <!-- Duration Trend Chart -->
            <Canvas x:Name="DurationTrendCanvas" Height="100"
                    HorizontalAlignment="Stretch" Margin="0,12,0,4" Visibility="Collapsed" />

            <!-- Duration Legend -->
            <StackPanel x:Name="DurationLegend" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,8,0,0" Visibility="Collapsed">
                <Ellipse Width="4" Height="4" Fill="#59B88061" />
                <TextBlock Text="{x:Static res:Strings.Session}" Foreground="Gray"
                           FontSize="10" Margin="4,0,12,0" VerticalAlignment="Center" />
                <Rectangle Width="12" Height="2" Fill="#B88061" RadiusX="1" RadiusY="1" />
                <TextBlock Text="{x:Static res:Strings.DurationAvg}" Foreground="Gray"
                           FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock x:Name="DurationLabel" Text="{x:Static res:Strings.DurationTrend}"
                       FontSize="10" Foreground="Gray" HorizontalAlignment="Center"
                       Margin="0,4,0,0" Visibility="Collapsed" />

        </StackPanel>
    </ScrollViewer>
</Window>
