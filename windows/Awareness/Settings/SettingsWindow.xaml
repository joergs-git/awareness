<Window x:Class="Awareness.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:settings="clr-namespace:Awareness.Settings"
        Title="Awareness Settings"
        Width="480" Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel Margin="20">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="☯" FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="Gray" />
                <TextBlock Text="Awareness Settings" FontSize="20" FontWeight="Medium"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Active Hours -->
            <GroupBox Header="🕐  Active Hours" Margin="0,0,0,12" Padding="10">
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="From" FontSize="11" Foreground="Gray" Margin="0,0,0,4" />
                        <ComboBox x:Name="StartHourCombo" Width="90"
                                  SelectionChanged="OnStartHourChanged" />
                    </StackPanel>
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Text="Until" FontSize="11" Foreground="Gray" Margin="0,0,0,4" />
                        <ComboBox x:Name="EndHourCombo" Width="90"
                                  SelectionChanged="OnEndHourChanged" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Interval Between Blackouts -->
            <GroupBox Header="⏱  Interval Between Blackouts" Margin="0,0,0,12" Padding="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                        <TextBlock x:Name="MinIntervalLabel" Width="55" TextAlignment="Right"
                                   Foreground="#4285F4" FontFamily="Consolas" />
                        <TextBlock Text=" – " Foreground="Gray" />
                        <TextBlock x:Name="MaxIntervalLabel" Width="55"
                                   Foreground="#4285F4" FontFamily="Consolas" />
                    </StackPanel>
                    <settings:RangeSlider x:Name="IntervalSlider"
                                          Minimum="1" Maximum="120" Step="1"
                                          LowValue="15" HighValue="30" />
                </StackPanel>
            </GroupBox>

            <!-- Blackout Duration -->
            <GroupBox Header="👁  Blackout Duration" Margin="0,0,0,12" Padding="10">
                <DockPanel Margin="0,4,0,0">
                    <TextBlock x:Name="DurationLabel" DockPanel.Dock="Right" Width="45"
                               TextAlignment="Right" Foreground="#4285F4" FontFamily="Consolas"
                               VerticalAlignment="Center" />
                    <Slider x:Name="DurationSlider" Minimum="3" Maximum="120"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnDurationChanged" />
                </DockPanel>
            </GroupBox>

            <!-- Blackout Visual -->
            <GroupBox Header="🎨  Blackout Visual" Margin="0,0,0,12" Padding="10">
                <StackPanel>
                    <!-- Visual type selector as radio buttons in a horizontal panel -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                        <RadioButton x:Name="RadioPlainBlack" Content="Plain Black"
                                     GroupName="VisualType" Margin="0,0,12,0"
                                     Checked="OnVisualTypeChanged" />
                        <RadioButton x:Name="RadioText" Content="Custom Text"
                                     GroupName="VisualType" Margin="0,0,12,0"
                                     Checked="OnVisualTypeChanged" />
                        <RadioButton x:Name="RadioImage" Content="Image"
                                     GroupName="VisualType" Margin="0,0,12,0"
                                     Checked="OnVisualTypeChanged" />
                        <RadioButton x:Name="RadioVideo" Content="Video"
                                     GroupName="VisualType"
                                     Checked="OnVisualTypeChanged" />
                    </StackPanel>

                    <!-- Text input (visible when Text mode is selected) -->
                    <DockPanel x:Name="TextPanel" Visibility="Collapsed" Margin="0,0,0,4">
                        <TextBlock Text="Display text:" DockPanel.Dock="Left"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="CustomTextBox" TextChanged="OnCustomTextChanged" />
                    </DockPanel>

                    <!-- Image picker (visible when Image mode is selected) -->
                    <DockPanel x:Name="ImagePanel" Visibility="Collapsed" Margin="0,0,0,4">
                        <Button Content="Choose..." DockPanel.Dock="Right" Margin="8,0,0,0"
                                Click="OnChooseImage" Padding="8,2" />
                        <Button x:Name="ClearImageButton" Content="✕" DockPanel.Dock="Right"
                                Margin="4,0,0,0" Click="OnClearImage" Padding="4,2"
                                Visibility="Collapsed" />
                        <TextBlock Text="Image:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="ImagePathLabel" Text="Default"
                                   Foreground="Gray" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>

                    <!-- Video picker (visible when Video mode is selected) -->
                    <DockPanel x:Name="VideoPanel" Visibility="Collapsed" Margin="0,0,0,4">
                        <Button Content="Choose..." DockPanel.Dock="Right" Margin="8,0,0,0"
                                Click="OnChooseVideo" Padding="8,2" />
                        <Button x:Name="ClearVideoButton" Content="✕" DockPanel.Dock="Right"
                                Margin="4,0,0,0" Click="OnClearVideo" Padding="4,2"
                                Visibility="Collapsed" />
                        <TextBlock Text="Video:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="VideoPathLabel" Text="None"
                                   Foreground="Gray" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- Sound -->
            <GroupBox Header="🔔  Sound" Margin="0,0,0,12" Padding="10">
                <StackPanel>
                    <CheckBox x:Name="StartGongCheck" Content="Start gong (begin of blackout)"
                              Margin="0,4,0,4" Checked="OnStartGongChanged" Unchecked="OnStartGongChanged" />
                    <CheckBox x:Name="EndGongCheck" Content="End gong (end of blackout)"
                              Margin="0,0,0,4" Checked="OnEndGongChanged" Unchecked="OnEndGongChanged" />
                </StackPanel>
            </GroupBox>

            <!-- Behavior -->
            <GroupBox Header="🔒  Behavior" Margin="0,0,0,12" Padding="10">
                <StackPanel>
                    <CheckBox x:Name="HandcuffsCheck" Content="Handcuffs mode"
                              Margin="0,4,0,4" Checked="OnHandcuffsChanged" Unchecked="OnHandcuffsChanged" />
                    <TextBlock Text="When on, ESC cannot dismiss the blackout early."
                               FontSize="11" Foreground="Gray" Margin="20,0,0,0" />
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
