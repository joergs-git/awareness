<Window x:Class="Awareness.Blackout.BlackoutOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Awareness.Blackout"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Opacity="0">

    <local:BlackoutContentControl x:Name="ContentControl" />
</Window>
