<UserControl x:Class="Awareness.Blackout.PostBlackoutControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Awareness.Resources"
             Background="Black">

    <Grid>

        <!-- ============================================================
             Phase 1: Awareness Check — "Were you there?" + three buttons
             Starts hidden (Opacity=0), fades in via ShowAwarenessCheck().
             ============================================================ -->
        <StackPanel x:Name="AwarenessPanel"
                    Opacity="0"
                    Visibility="Visible"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Orientation="Vertical">

            <!-- Question text -->
            <TextBlock Text="{x:Static res:Strings.WereYouThere}"
                       Foreground="#D9FFFFFF"
                       FontSize="28"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,28" />

            <!-- Response buttons: Yes / Somewhat / No -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <!-- "Yes" button -->
                <Button x:Name="YesButton"
                        Content="{x:Static res:Strings.Yes}"
                        Click="OnYesClicked"
                        Margin="0,0,12,0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                                    BorderBrush="#4DFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#D9FFFFFF" />
                    </Button.Foreground>
                    <Button.FontSize>16</Button.FontSize>
                </Button>

                <!-- "Somewhat" button -->
                <Button x:Name="SomewhatButton"
                        Content="{x:Static res:Strings.Somewhat}"
                        Click="OnSomewhatClicked"
                        Margin="0,0,12,0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                                    BorderBrush="#4DFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#D9FFFFFF" />
                    </Button.Foreground>
                    <Button.FontSize>16</Button.FontSize>
                </Button>

                <!-- "No" button -->
                <Button x:Name="NoButton"
                        Content="{x:Static res:Strings.No}"
                        Click="OnNoClicked"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                                    BorderBrush="#4DFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#D9FFFFFF" />
                    </Button.Foreground>
                    <Button.FontSize>16</Button.FontSize>
                </Button>

            </StackPanel>
        </StackPanel>

        <!-- ============================================================
             Phase 2: Practice Card — title, separator, micro-task, hint
             Hidden initially; fades in via ShowPracticeCard().
             The entire panel is a click target for dismissal.
             ============================================================ -->
        <Grid x:Name="CardPanel"
              Opacity="0"
              Visibility="Collapsed"
              Background="Transparent"
              Cursor="Hand"
              MouseLeftButtonDown="OnCardClicked">

            <!-- Vertically centered card content -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Orientation="Vertical">

                <!-- Card title -->
                <TextBlock x:Name="CardTitleText"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="600"
                           Margin="0,0,0,16" />

                <!-- Thin 1px white separator (120px wide, 20% opacity) -->
                <Rectangle Width="120"
                           Height="1"
                           Fill="#33FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20" />

                <!-- Micro-task text: italic, 18pt, 60% opacity -->
                <TextBlock x:Name="MicroTaskText"
                           Foreground="#99FFFFFF"
                           FontSize="18"
                           FontStyle="Italic"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           Visibility="Collapsed" />

            </StackPanel>

            <!-- "click anywhere to continue" hint anchored to bottom -->
            <TextBlock Text="{x:Static res:Strings.ClickAnywhere}"
                       Foreground="#4DFFFFFF"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,32" />

        </Grid>

    </Grid>
</UserControl>
