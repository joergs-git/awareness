<UserControl x:Class="Awareness.Blackout.PostBlackoutControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Awareness.Resources"
             Background="Black">

    <Grid>

        <!-- ============================================================
             Phase 1: Awareness Check — "Were you there?" + slider (0–100)
             Starts hidden (Opacity=0), fades in via ShowAwarenessCheck().
             ============================================================ -->
        <StackPanel x:Name="AwarenessPanel"
                    Opacity="0"
                    Visibility="Visible"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Orientation="Vertical">

            <!-- Question text -->
            <TextBlock Text="{x:Static res:Strings.WereYouThere}"
                       Foreground="#D9FFFFFF"
                       FontSize="28"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,28" />

            <!-- Slider labels: No / Yes -->
            <Grid Width="300" Margin="0,0,0,8">
                <TextBlock Text="{x:Static res:Strings.No}"
                           Foreground="#80FFFFFF"
                           FontSize="14"
                           HorizontalAlignment="Left" />
                <TextBlock Text="{x:Static res:Strings.Yes}"
                           Foreground="#80FFFFFF"
                           FontSize="14"
                           HorizontalAlignment="Right" />
            </Grid>

            <!-- Awareness slider (0–100) -->
            <Slider x:Name="AwarenessSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="50"
                    Width="300"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    Thumb.DragCompleted="OnSliderDragCompleted"
                    Cursor="Hand" />

        </StackPanel>

        <!-- ============================================================
             Phase 2: Practice Card — title, separator, micro-task, hint
             Hidden initially; fades in via ShowPracticeCard().
             The entire panel is a click target for dismissal.
             ============================================================ -->
        <Grid x:Name="CardPanel"
              Opacity="0"
              Visibility="Collapsed"
              Background="Transparent"
              Cursor="Hand"
              MouseLeftButtonDown="OnCardClicked">

            <!-- Vertically centered card content -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Orientation="Vertical">

                <!-- Card title -->
                <TextBlock x:Name="CardTitleText"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="600"
                           Margin="0,0,0,16" />

                <!-- Thin 1px white separator (120px wide, 20% opacity) -->
                <Rectangle Width="120"
                           Height="1"
                           Fill="#33FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20" />

                <!-- Micro-task text: italic, 18pt, 60% opacity -->
                <TextBlock x:Name="MicroTaskText"
                           Foreground="#99FFFFFF"
                           FontSize="18"
                           FontStyle="Italic"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           Visibility="Collapsed" />

            </StackPanel>

            <!-- "click anywhere to continue" hint anchored to bottom -->
            <TextBlock Text="{x:Static res:Strings.ClickAnywhere}"
                       Foreground="#4DFFFFFF"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,32" />

        </Grid>

    </Grid>
</UserControl>
