<UserControl x:Class="Awareness.Blackout.ConfirmationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Awareness.Resources"
             Background="Black">

    <!-- Full-screen centered layout for startclick confirmation prompt -->
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

            <!-- "Ready to breathe?" question -->
            <TextBlock Text="{x:Static res:Strings.ReadyToBreathe}"
                       Foreground="#CCFFFFFF"
                       FontSize="28"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,32" />

            <!-- Yes / No buttons side by side -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0">

                <!-- Yes: prominent — white text, white 20% background -->
                <Button x:Name="YesButton"
                        Content="{x:Static res:Strings.Yes}"
                        Click="OnYesClicked"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Normal"
                        Padding="24,12"
                        Margin="0,0,16,0"
                        Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#33FFFFFF"
                                    CornerRadius="20"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- No: subdued — 50% opacity text, white 8% background -->
                <Button x:Name="NoButton"
                        Content="{x:Static res:Strings.No}"
                        Click="OnNoClicked"
                        Foreground="#80FFFFFF"
                        FontSize="16"
                        FontWeight="Normal"
                        Padding="24,12"
                        Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#14FFFFFF"
                                    CornerRadius="20"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
