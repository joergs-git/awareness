<UserControl x:Class="Awareness.Blackout.BlackoutContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Awareness.Resources"
             Background="Black">

    <Grid x:Name="ContentGrid">
        <!-- Plain black: subtle breathing circle as minimal visual anchor -->
        <Ellipse x:Name="BreathingCircle"
                 Visibility="Collapsed"
                 Width="12" Height="12"
                 Fill="#04FFFFFF"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="CircleScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Text mode: centered white text with breathing animation -->
        <TextBlock x:Name="TextContent"
                   Visibility="Collapsed"
                   Text="{x:Static res:Strings.Breathe}"
                   Foreground="#CCFFFFFF"
                   FontSize="36"
                   FontWeight="Light"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="40"
                   RenderTransformOrigin="0.5,0.5">
            <TextBlock.RenderTransform>
                <ScaleTransform x:Name="TextScale" ScaleX="1" ScaleY="1" />
            </TextBlock.RenderTransform>
        </TextBlock>

        <!-- Image mode: centered scaled image with breathing animation -->
        <Image x:Name="ImageContent"
               Visibility="Collapsed"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
            </Image.RenderTransform>
        </Image>

        <!-- Video mode: looping video -->
        <MediaElement x:Name="VideoContent"
                      Visibility="Collapsed"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Video fallback text -->
        <TextBlock x:Name="VideoFallback"
                   Visibility="Collapsed"
                   Text="{x:Static res:Strings.NoVideoSelected}"
                   Foreground="#4DFFFFFF"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>
