<UserControl x:Class="Awareness.Blackout.BlackoutContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Awareness.Resources"
             Background="Black">

    <Grid x:Name="ContentGrid">
        <!-- Plain black: just the black background, nothing else -->

        <!-- Text mode: centered white text -->
        <TextBlock x:Name="TextContent"
                   Visibility="Collapsed"
                   Text="{x:Static res:Strings.Breathe}"
                   Foreground="#CCFFFFFF"
                   FontSize="36"
                   FontWeight="Light"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="40" />

        <!-- Image mode: centered scaled image -->
        <Image x:Name="ImageContent"
               Visibility="Collapsed"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />

        <!-- Video mode: looping video -->
        <MediaElement x:Name="VideoContent"
                      Visibility="Collapsed"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Video fallback text -->
        <TextBlock x:Name="VideoFallback"
                   Visibility="Collapsed"
                   Text="{x:Static res:Strings.NoVideoSelected}"
                   Foreground="#4DFFFFFF"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>
