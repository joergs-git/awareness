      }
    },
    "The eye cannot see itself — who is it that is aware?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Auge kann sich selbst nicht sehen — wer ist es, der gewahr ist?"
          }
        }
      }
    },
    "The finger pointing at the moon is not the moon" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Finger, der auf den Mond zeigt, ist nicht der Mond"
