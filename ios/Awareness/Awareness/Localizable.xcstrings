    },
    "This moment." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Moment."
          }
        }
      }
    },
    "This will pull the latest desktop data and then create a new sync key. You must enter the new key on your Mac or Windows app before it will work again — otherwise desktop breaks will be lost in transit." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die neuesten Desktop-Daten werden abgerufen und dann ein neuer Sync-Schlüssel erzeugt. Du musst den neuen Schlüssel in deiner Mac- oder Windows-App eingeben, bevor es wieder funktioniert — sonst gehen Desktop-Pausen bei der Übertragung verloren."
          }
        }
      }
    },
    "Time to pause and breathe" : {
      "localizations" : {
