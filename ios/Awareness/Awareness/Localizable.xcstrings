        }
      }
    },
    "☯ %lld/%lld %@" : {
      "comment" : "A formatted string showing the user's progress towards a goal, followed by the time until the goal is reached. The first argument is the number of goals completed. The second argument is the number of goals remaining. The third argument is a formatted time string representing the time until the goal is reached.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
