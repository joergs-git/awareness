    "🙏" : {
      "comment" : "A Unicode character for a 'raised hand' emoji.",
      "isCommentAutoGenerated" : true
    },
    "A mindfulness timer for your Mac.\nRandomly pauses your screen to help you breathe.\n\nThe goal of this app is to not need it anymore a little bit later.\n\nby joergsflow\nVersion %@\n\ngithub.com/joergs-git/awareness" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Achtsamkeits-Timer für deinen Mac.\nPausiert zufällig deinen Bildschirm, um dir beim Atmen zu helfen.\n\nDas Ziel dieser App ist, sie ein wenig später nicht mehr zu brauchen.\n\nvon joergsflow\nVersion %@\n\ngithub.com/joergs-git/awareness"
          }
        }
      }
    },
    "About Atempause..." : {
      "comment" : "Title of the \"About\" menu item in the status bar.",
      "isCommentAutoGenerated" : true
    },
    "About Awareness..." : {
